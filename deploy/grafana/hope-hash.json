    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisLabel": "diff",
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineInterpolation": "stepAfter",
